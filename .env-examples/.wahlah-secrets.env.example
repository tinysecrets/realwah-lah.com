# Copy to repo root as .wahlah-secrets.env (gitignored), fill secrets, then:
#   npm run deploy:secrets
#   npm run deploy:backend

# MongoDB Atlas — Network Access must allow 0.0.0.0/0 for Fly.io
MONGO_URL=
DB_NAME=sugar_city_sweeps

# Auto-generated if blank when running scripts/deploy.sh
JWT_SECRET=
PROXY_ENCRYPTION_KEY=

# Owner account (jrs092393@gmail.com)
ADMIN_EMAIL=jrs092393@gmail.com
ADMIN_PASSWORD=

# Stripe — secret key required for card deposits (sk_live_ or rk_live_)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM='WAH-LAH <onboarding@resend.dev>'
CUSTOM_EMAIL_FROM='WAH-LAH <noreply@wah-lah.com>'

# Domains / cookies
FRONTEND_URL='https://wah-lah.com'
CORS_ORIGINS='https://wah-lah.com,https://www.wah-lah.com,https://api.wah-lah.com'
COOKIE_SECURE=true
COOKIE_SAMESITE='lax'
ENFORCE_CANONICAL_HOST=true
CANONICAL_HOST='wah-lah.com'
CARD_PAYMENT_TAG='$jrs092393'

# Boss Genie LLM
CEREBRAS_API_KEY=
CEREBRAS_MODEL='qwen-3-235b-a22b-instruct-2507'

# Cloudflare DNS (Boss Genie deploy tools)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Optional: Sugar Sweeps Playwright hub
SUGAR_SWEEPS_USERNAME=jrs092393@gmail.com
SUGAR_SWEEPS_PASSWORD=
SUGAR_SWEEPS_URL='https://sugarsweeps.com'

# Compliance / revenue defaults
BLOCKED_STATES='WA,ID,MT,NV,LA,TN,MI,UT,AZ'
KYC_BASIC_THRESHOLD_USD=500
KYC_ENHANCED_THRESHOLD_USD=5000
CTR_THRESHOLD_USD=10000
SAR_FREQ_WINDOW_HOURS=24
SAR_FREQ_THRESHOLD=3
CASHTAG_KEEP_RATE=0.12
GIFTCARD_FEE_RATE=0.05
BTC_FEE_RATE=0.10
PROXY_DEFAULT_PER_TRANSFER_CAP=500
PROXY_DEFAULT_DAILY_CAP=5000
PROXY_COOLDOWN_FAILURES=3
PROXY_LOCK_FAILURES=5
PROXY_COOLDOWN_MINUTES=30
