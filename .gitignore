# ============================================================================
# WAH-LAH — .gitignore (deduped, single source of truth)
# ============================================================================

# VCS / IDE
.git
.gitignore
.github
.vscode
.idea
.DS_Store
*.swp
*.swo
*~

# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
ENV/
env/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# Node — frontend is built in-image, never ship host artifacts
frontend/node_modules
frontend/build
frontend/.cache
genie-sidekick/node_modules
genie-sidekick/dist

# Fly / Local deployment
.wahlah-secrets.env
.genie-secrets.env
.wahlah
.flyrc

# Docker
Dockerfile.local
docker-compose.local.yml

# Local infra wrapper artifacts
Makefile.local
start.local.sh

# Logs / scratch / reports
*.log
test_reports/
tests/__snapshots__/
*.tmp

# Docs — runtime doesn't need them (optional, safe to keep)
# docs/
# memory/

# Secrets — Fly/Render inject env at runtime
.env
.env.local
.env.*.local
.env.*.example

# Temp / uploads
/tmp/
uploads/
**/.uploads/
*.zip
*.tar
*.tar.gz
.gitkeep